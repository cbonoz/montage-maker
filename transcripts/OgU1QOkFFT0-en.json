    "duration": 3.1
  },
  {
    "text": "Spaniard.",
    "start": 77.759,
    "duration": 3.0
  },
  {
    "text": "I'm coming up.",
    "start": 97.439,
    "duration": 3.401
  },
  {
    "text": "That's enough for the moment.",
    "start": 112.479,
    "duration": 5.741
  },
  {
    "text": "His time will come.",
    "start": 115.04,
    "duration": 8.16
  },
